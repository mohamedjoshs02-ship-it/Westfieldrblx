<title>Westfield School</title>

<style>
    body {
        margin: 0;
        font-family: Arial, sans-serif;
        background: linear-gradient(135deg, #5a0000, #b30000);
        color: white;
        text-align: center;
    }

    .card {
        max-width: 400px;
        margin: 60px auto;
        background: rgba(0,0,0,0.4);
        padding: 25px;
        border-radius: 15px;
        box-shadow: 0 0 20px rgba(0,0,0,0.5);
    }

    img {
        width: 120px;
        border-radius: 50%;
        margin-bottom: 15px;
        border: 3px solid white;
    }

    h1 {
        margin: 10px 0;
    }

    p {
        opacity: 0.9;
        line-height: 1.5;
    }

    .link {
        display: block;
        background: white;
        color: #b30000;
        text-decoration: none;
        margin: 12px 0;
        padding: 12px;
        border-radius: 8px;
        font-weight: bold;
        transition: 0.2s;
    }

    .link:hover {
        background: #eee;
        transform: scale(1.05);
    }
</style>
</head>

